# =============================================================================
# VERKING Mobile — environment variables
# Copy this file to `.env` and fill in the real values from your Supabase project.
# Only EXPO_PUBLIC_* variables are exposed to the React Native bundle.
# Never put service_role keys here. The mobile app must only use the publishable
# (anon) key.
# =============================================================================

# Supabase project URL (https://<ref>.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Supabase publishable / anon key (sb_publishable_... or legacy anon JWT).
# DO NOT use the service_role key here.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
